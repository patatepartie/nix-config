{
  "permissions": {
    "allow": [
      "Bash(claude hooks:*)",
      "Bash(command tmux:*)",
      "Bash(just:*)",
      "Bash(nix-prefetch-url:*)",
      "Bash(nix:*)",
      "Bash(ssh home-server.local cat:*)",
      "Bash(ssh home-server.local journalctl:*)",
      "Bash(ssh home-server.local ls:*)",
      "Bash(ssh home-server.local nixos-version:*)",
      "Bash(ssh home-server.local systemctl is-active:*)",
      "Bash(ssh home-server.local systemctl list-timers:*)",
      "Bash(ssh home-server.local systemctl list-units:*)",
      "Bash(ssh home-server.local systemctl status:*)",
      "Bash(ssh home-server.local systemd-inhibit:*)",
      "Bash(ssh home-server.local uname:*)",
      "Bash(ssh home-server.local uptime:*)",
      "Glob(//nix/store/**)",
      "Grep(//nix/store/**)",
      "Read(//nix/store/**)",
      "WebFetch(domain:discourse.nixos.org)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:nix-darwin.github.io)",
      "WebFetch(domain:nixos.wiki)",
      "WebFetch(domain:support.apple.com)",
      "WebFetch(domain:www.unix.com)"
    ]
  },
  "sandbox": {
    "excludedCommands": [
      "just build",
      "just switch",
      "just upgrade",
      "ssh home-server.local *"
    ],
    "filesystem": {
      "allowWrite": ["~/.cache/nix"]
    }
  }
}
